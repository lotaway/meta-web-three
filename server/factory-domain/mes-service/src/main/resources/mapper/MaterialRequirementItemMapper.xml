<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.metawebthree.mes.infrastructure.persistence.mapper.MaterialRequirementItemMapper">
    
    <select id="findByRequirementId" resultType="com.metawebthree.mes.infrastructure.persistence.dataobject.MaterialRequirementItemDO">
        SELECT * FROM mes_material_requirement_item WHERE requirement_id = #{requirementId}
    </select>
    
    <delete id="deleteByRequirementId">
        DELETE FROM mes_material_requirement_item WHERE requirement_id = #{requirementId}
    </delete>
</mapper>