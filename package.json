{
  "name": "meta-web-three",
  "version": "1.0.2-20230225",
  "description": "_本项目为商城+AI风控+AI仓储+ERP+数字化工厂+（可选）区块链商品 相关_",
  "author": "",
  "license": "UNLICENSED",
  "scripts": {
    "activate": "mamba activate meta-web-three-ai",
    "dev": "node run-dev.js",
    "build": "docker build -t wayluk/meta-web-three:1.0.2 .",
    "init:env": "docker compose -f ./docker-compose.env.yml up",
    "start:env": "docker compose -f ./docker-compose.env.yml start",
    "stop:env": "docker compose -f ./docker-compose.env.yml stop",
    "delete:env": "docker compose -f ./docker-compose.env.yml down",
    "delete:system:docker:env": "docker stop $(docker ps -aq) && docker rm $(docker ps -aq)",
    "test:e2e": "cd apps/digital-twin/system-management && npm run test:e2e",
    "test:e2e:ui": "cd apps/digital-twin/system-management && npm run test:e2e:ui"
  },
  "dependencies": {
    "caniuse-lite": "^1.0.30001519",
    "ethers": "^6.13.4",
    "expo-image-picker": "^55.0.19"
  },
  "main": "index.js",
  "keywords": [],
  "bugs": {
    "url": "https://github.com/lotaway/meta-web-three/issues"
  },
  "homepage": "https://github.com/lotaway/meta-web-three#readme",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "dotenv": "^17.4.2",
    "playwright": "^1.60.0"
  }
}
