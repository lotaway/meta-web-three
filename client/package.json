{
  "name": "meta-web-three-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:sw": "cross-env NODE_ENV=production node tools/BuildSW.js",
    "debug:sw": "node tools/BuildSW.js --sourceMap",
    "generate:api": "node tools/OpenApiToTS.js",
    "generate:enum": "node tools/JEnumToTS.js",
    "generate:contract:abi": "node tools/CopyContractABIToTs.js",
    "pkg": "node tools/PackageOutput.js",
    "package": "yarn build && yarn pkg",
    "preinstall": "cd ./turbo-module/appsdk && yarn install",
    "setup:sdks": "node scripts/download-sdks.js",
    "setup:ios-sdks": "node scripts/download-sdks.js --ios",
    "setup:android-sdks": "node scripts/download-sdks.js --android",
    "start": "npx expo start --dev-client",
    "reset-project": "node ./scripts/reset-project.js",
    "eandroid": "npx expo start --android",
    "android": "npx expo run:android",
    "android:cache": "npx expo run:android --no-build",
    "eios": "npx expo start --ios",
    "ios": "npx expo run:ios",
    "ios:cache": "npx expo run:ios --no-build",
    "clean": "npx react-native clean",
    "rebuild": "npx expo prebuild --clean",
    "check:expo": "npx expo install --check",
    "fix:expo": "npx expo install --fix",
    "web": "npx expo start --web",
    "create:module": "npx create-expo-module modules/appsdk",
    "create:sdk": "npx create-react-native-library@latest ../turbo-module/appsdk",
    "lint": "npx expo lint",
    "update:sdk": "yarn upgrade react-native-appsdk",
    "open:AndroidStudio": "open -a '/Applications/Android Studio.app' ./android",
    "build:android": "cd android && ./gradlew :app:generateDebugSources",
    "build:ios": "npm run pod",
    "edit:ios": "open ios/metawebthreeapp.xcworkspace"
  },}
