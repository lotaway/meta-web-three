# ==================== Backend API ====================
NEXT_PUBLIC_BACK_API_DOC_HOST=http://localhost:10081 # backend openapi doc
NEXT_PUBLIC_BACK_API_HOST= # backend api host
BACKEND_API_ROOT_DIR= # backend java program root directory
CONTRACT_ROOT_DIR=../evm-contract # contract program root directory

# ==================== iOS Certificate ====================
CN=
Orginazation=
OrganizationalUnit=
City=
Province=
CountryCode=

EXPO_PUBLIC_PASSKEY_ENABLED= #default=false
# Relying Party ID — 必须与后端配置及 iOS Associated Domains 中的域名完全一致。
# 本地开发可填 localhost，生产环境填实际域名（例如 example.com）。
EXPO_PUBLIC_RP_ID=localhost
EXPO_PUBLIC_DEFAULT_USER_ID=1
EXPO_PUBLIC_WECHAT_APP_ID=
EXPO_PUBLIC_ALIPAY_APP_ID=
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
