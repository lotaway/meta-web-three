{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "esnext",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "paths": {
      "@/components/order/*": [
        "app/components/order/*"
      ],
      "@/components/profile/*": [
        "app/components/profile/*"
      ],
      "@/components/product/*": [
        "app/components/product/*"
      ],
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "expo-env.d.ts",
    "plugins/with-native-build-config.js",
    ".expo/types/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "e2e",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "test/**",
    "modules/*/example",
    "modules/scanner-module/src/ScannerModuleView.web.tsx",
    "node_modules",
    "src/generated/api/apis/index.ts"
  ]
}
